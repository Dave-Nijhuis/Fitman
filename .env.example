# Copy this file to .env and fill in your values.
# .env is gitignored — never commit it.

# ── Auth ──────────────────────────────────────────────────────────────────────
# Secret key used to sign JWT tokens. Generate one with:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me

# Login credentials for the app (single user)
ADMIN_USERNAME=dave
# Store ADMIN_PASSWORD as a bcrypt hash for security. Generate one with:
#   python -c "import bcrypt; print(bcrypt.hashpw(b'yourpassword', bcrypt.gensalt()).decode())"
# Plaintext passwords still work but will log a warning on startup.
ADMIN_PASSWORD=change-me

# How many days a login token stays valid before you need to log in again
JWT_EXPIRE_DAYS=7

# ── Database ──────────────────────────────────────────────────────────────────
# Path inside the container where the SQLite file is stored.
# Mapped to the db_data Docker volume — do not change unless you know why.
DATA_DIR=/app/data

# ── Smart scale ingestion ─────────────────────────────────────────────────────
# Used by scripts/scale_ingest.py — not required for the server itself.
FITMAN_API_URL=http://localhost:8000
SCALE_AGE=30
SCALE_HEIGHT_CM=180
SCALE_SEX=1

# ── CORS ──────────────────────────────────────────────────────────────────────
# Which origins the backend will accept requests from.
# In development this is the Vite dev server.
# In production set this to your Tailscale hostname, e.g. http://fitman
CORS_ORIGINS=http://localhost:3000
